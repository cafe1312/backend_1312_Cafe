datasource db {
  provider  = "sqlite"
  url       = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Admin {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String   @map("password_hash")
  role         String   @default("admin")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("admins")
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String   @unique
  address   String?
  createdAt DateTime @default(now()) @map("created_at")
  orders    Order[]

  @@map("customers")
}

model Category {
  id            Int       @id @default(autoincrement())
  name          String    @unique
  image         String?
  availableFrom String?   @map("available_from")
  availableTo   String?   @map("available_to")
  products      Product[]

  @@map("categories")
}

model Product {
  id          Int         @id @default(autoincrement())
  categoryId  Int         @map("category_id")
  name        String
  description String?
  price       Float
  image       String?
  available   Boolean     @default(true)
  isVeg       Boolean     @default(true) @map("is_veg")
  createdAt   DateTime    @default(now()) @map("created_at")
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]

  @@map("products")
}

model Order {
  id             Int         @id @default(autoincrement())
  customerId     Int         @map("customer_id")
  totalAmount    Float       @map("total_amount")
  paymentMethod  String      @map("payment_method")
  paymentStatus  String      @map("payment_status")
  status         String      @default("PENDING") // PENDING, PREPARING, READY, COMPLETED, CANCELLED
  deliveryMethod String      @default("TAKEAWAY") @map("delivery_method")
  address        String?
  latitude       Float?
  longitude      Float?
  distance       Float?
  deliveryCharges Float?      @map("delivery_charges")
  createdAt      DateTime    @default(now()) @map("created_at")
  customer       Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items          OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int     @map("order_id")
  productId Int     @map("product_id")
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model Coupon {
  id       Int     @id @default(autoincrement())
  code     String  @unique
  discount Float
  active   Boolean @default(true)

  @@map("coupons")
}
